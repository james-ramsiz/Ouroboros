use crate::config::SimConfig;
use rand::rngs::SmallRng;
use rand::{Rng, SeedableRng};

pub struct SimState {
    pub rng: SmallRng,
    pub mutation_rate: f32,
    pub color_phase: f32,
    pub frame_count: u64,
    pub width: u32, pub height: u32,
    pub prev_ssim: f32, pub prev_entropy: f32,
}

impl SimState {
    pub fn new(cfg: &SimConfig) -> Self {
        Self {
            rng: SmallRng::seed_from_u64(cfg.seed),
            mutation_rate: cfg.base_mutation_rate,
            color_phase: 0.0,
            frame_count: 0, width: cfg.width, height: cfg.height,
            prev_ssim: 1.0, prev_entropy: 0.0,
        }
    }

    /// Meta feedback: SSIM & Entropy directly mutate simulation rules
    pub fn evolve_rules(&mut self, cfg: &SimConfig, ssim: f32, entropy: f32) {
        // High SSIM = system stabilized -> increase mutation to force divergence
        // High Entropy = high disorder -> dampen phase shift to regain structure
        let divergence_pressure = (1.0 - ssim) * 0.02;
        let order_pressure = (1.0 - entropy) * 0.015;

        self.mutation_rate = (self.mutation_rate + divergence_pressure - 0.002)
            .clamp(0.005, 0.25);
        self.color_phase += cfg.color_shift_speed + order_pressure;
        self.prev_ssim = ssim; self.prev_entropy = entropy;
        self.frame_count += 1;
    }
}
